# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENDPOINT_BASE=https://generativelanguage.googleapis.com/v1

# Oracle DB
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_TNS=host:port/service_name

# Oracle Connection Pool
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# External Java API Server (재고/배송 조회용)
JAVA_SERVER_URL=http://localhost:8080
