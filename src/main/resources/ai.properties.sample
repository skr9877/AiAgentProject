# =============================================
# ai.properties.sample
# 이 파일을 복사해서 ai.properties로 만들고
# 실제 값을 채워 넣으세요.
# ai.properties는 .gitignore에 등록되어 있어
# 커밋되지 않습니다.
# =============================================

# Gemini AI API 키 (Google AI Studio에서 발급)
# https://aistudio.google.com/app/apikey
gemini.api-key=YOUR_GEMINI_API_KEY

# 사용할 Gemini 모델명
gemini.model=gemini-2.5-flash

# Gemini REST API 엔드포인트 (변경 불필요)
gemini.endpoint-base=https://generativelanguage.googleapis.com/v1beta
